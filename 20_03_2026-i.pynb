{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPA6Bn+xnxfIcyB9nMOqDol"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["from sklearn import model_selection\n","from ast import mod\n","\n","#import required libraries\n","import numpy as np\n","import pandas as pd\n","\n","#Dataset\n","from sklearn.datasets import load_iris\n","\n","#Train-test split\n","from sklearn.model_selection import train_test_split\n","\n","#Decison Tree Model\n","from sklearn.tree import DecisionTreeClassifier\n","\n","#Evaluation metrices\n","from sklearn.metrics import accuracy_score\n","\n","#Hyperparameter tuning\n","from sklearn.model_selection import GridSearchCV\n","\n","#Load Iris dataset\n","data=load_iris()\n","\n","#features (x) and Target (y)\n","X=data.data\n","y=data.target\n","\n","#split into training  and testing data\n","X_train,X_test,y_train,y_test=train_test_split(\n","    X,y,test_size=0.3,random_state=42\n",")\n","\n","print(\"Training samples:\",X_train.shape[0])\n","print(\"Testing samples:\",X_test.shape[0])\n","\n","#Train Decision Tree (Overfitting Example)\n","#Create Decision Tree with NO restrictions\n","model = DecisionTreeClassifier(random_state=42)\n","\n","#Train the model\n","model.fit(X_train, y_train)\n","\n","#Predictions\n","train_pred = model.predict(X_train)\n","test_pred = model.predict(X_test)\n","\n","#Accuracy\n","train_acc = accuracy_score(y_train, train_pred)\n","test_acc = accuracy_score(y_test, test_pred)\n","print(\"\\n----Before Hyperparameter Tuning----\")\n","print(\"Training Accuracy:\", train_acc)\n","print(\"Testing Accuracy:\", test_acc)\n","\n","#If training accuracy is very high and testing accuracy is lower,\n","#it indicates OVERFITTING\n","\n","#Limit tree complexity\n","model_tuned = DecisionTreeClassifier(\n","max_depth=3,\n","  min_samples_split=5,\n","  random_state=42)\n","\n","#Train tuned model\n","model_tuned.fit(X_train, y_train)\n","\n","#predictions\n","train_pred2 = model_tuned.predict(X_train)\n","test_pred2 = model_tuned.predict(X_test)\n","\n","#Accuracy\n","train_acc2 = accuracy_score(y_train, train_pred2)\n","test_acc2 = accuracy_score(y_test, test_pred2)\n","\n","print(\"\\n----After Hyperparameter Tuning----\")\n","print(\"Training Accuracy:\", train_acc2)\n","print(\"Testing Accuracy:\", test_acc2)\n","\n","#Hyperparameter tuning using GridSearchCV\n","\n","#define parameter grid\n","\n","param_grid={\n","    'max_depth': [2, 3, 4, 5,6],\n","    'min_samples_split':[2,5,10],\n","    'min_samples_leaf':[1,2,4]\n","}\n","\n","#create base model\n","\n","dt=DecisionTreeClassifier(random_state=42)\n","\n","#GridSearchCV\n","\n","grid=GridSearchCV(\n","    estimator=dt,\n","    param_grid=param_grid,\n","    cv=5,\n","    scoring='accuracy'\n",")\n","\n","#Train grid search\n","grid.fit(X_train, y_train)\n","\n","#Best parameters\n","print(\"\\nBest Parameters Found:\", grid.best_params_)\n","\n","#Best model\n","best_model=grid.best_estimator_\n","\n","#predictions\n","y_pred = best_model.predict(X_test)\n","\n","#Final Accuracy\n","final_acc = accuracy_score(y_test, y_pred)\n","print(\"Final Test Accuracy after GridSearch CV:\", final_acc)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"IRv0XrOmnqw_","executionInfo":{"status":"ok","timestamp":1774003057828,"user_tz":-330,"elapsed":620,"user":{"displayName":"Pratigya Sinha","userId":"06442991612063408557"}},"outputId":"d52e7b38-5a29-4340-e63c-87f9732842ce"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Training samples: 105\n","Testing samples: 45\n","\n","----Before Hyperparameter Tuning----\n","Training Accuracy: 1.0\n","Testing Accuracy: 1.0\n","\n","----After Hyperparameter Tuning----\n","Training Accuracy: 0.9523809523809523\n","Testing Accuracy: 1.0\n","\n","Best Parameters Found: {'max_depth': 4, 'min_samples_leaf': 1, 'min_samples_split': 10}\n","Final Test Accuracy after GridSearch CV: 1.0\n"]}]}]}